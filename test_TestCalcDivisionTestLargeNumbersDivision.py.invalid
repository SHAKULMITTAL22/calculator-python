# Updated test file: test_calc_division.py

import pytest
from source.calculator_python.calc.division import division

class TestCalcDivision:
    @pytest.mark.positive
    def test_division_large_positive_numbers(self):
        # Arrange
        num1 = 1000000
        num2 = 100
        expected_result = 10000

        # Act
        result = division(num1, num2)

        # Assert
        assert result == expected_result

    @pytest.mark.invalid
    def test_division_by_zero(self):
        # Arrange
        num1 = 1000000
        num2 = 0
        expected_result = "Cannot divide by zero"

        # Act
        result = division(num1, num2)

        # Assert
        assert result == expected_result

    @pytest.mark.performance
    def test_division_large_numbers_fractional_result(self):
        # Arrange
        num1 = 1000001
        num2 = 100
        expected_result = 10000.01

        # Act
        result = division(num1, num2)

        # Assert
        assert result == pytest.approx(expected_result)

    @pytest.mark.negative
    def test_division_with_negative_values(self):
        # Arrange
        num1 = 1000000
        num2 = -100
        expected_result = -10000

        # Act
        result = division(num1, num2)

        # Assert
        assert result == expected_result

    @pytest.mark.negative
    def test_division_negative_dividend_and_positive_divisor(self):
        # Arrange
        num1 = -1000000
        num2 = 100
        expected_result = -10000

        # Act
        result = division(num1, num2)

        # Assert
        assert result == expected_result

    @pytest.mark.positive
    def test_division_both_negative_numbers(self):
        # Arrange
        num1 = -1000000
        num2 = -100
        expected_result = 10000

        # Act
        result = division(num1, num2)

        # Assert
        assert result == expected_result

    @pytest.mark.regression
    def test_division_result_zero(self):
        # Arrange
        num1 = 0
        num2 = 1000000
        expected_result = 0

        # Act
        result = division(num1, num2)

        # Assert
        assert result == expected_result

    @pytest.mark.security
    def test_division_with_high_precision(self):
        # Arrange
        num1 = 123456.789
        num2 = 123.456
        expected_result = 1000.001  # Ensured expected result is in line with high precision

        # Act
        result = division(num1, num2)

        # Assert
        assert result == pytest.approx(expected_result)
